/* records 页面：操作按钮 + 弹窗（删除二次确认）样式 */

/* 记录操作区域样式 */
.record-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.record-date {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.action-buttons {
  display: flex;
  gap: 10rpx;
}

.delete-btn {
  background: #ff4757;
  color: white;
  border: none;
  border-radius: 6rpx;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  min-width: 80rpx;
}

.delete-btn:active {
  background: #ff3838;
}

.add-record-btn {
  background: #07c160;
  color: white;
  border: none;
  border-radius: 6rpx;
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  min-width: 80rpx;
}

.add-record-btn:active {
  background: #06ad56;
}

/* 回到顶部浮窗按钮 */
.back-to-top {
  position: fixed;
  bottom: 120rpx;
  right: 40rpx;
  width: 80rpx;
  height: 80rpx;
  background: rgba(74, 144, 226, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 999;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.back-to-top:active {
  background: rgba(58, 123, 200, 0.9);
  transform: scale(0.95);
}

.back-to-top-icon {
  color: white;
  font-size: 32rpx;
  font-weight: bold;
}

/* 二次确认弹窗：覆盖屏幕居中 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  background: #fff;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.delete-confirm-btn {
  background: #ff4757 !important;
  color: white !important;
}

.delete-confirm-btn:active {
  background: #ff3838 !important;
}

.delete-warning {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background: #fff3cd;
  border-radius: 8rpx;
  border: 1rpx solid #ffeaa7;
}

.warning-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.warning-text {
  font-size: 28rpx;
  color: #856404;
  font-weight: bold;
}

.record-info {
  background: #f8f9fa;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.info-item {
  display: flex;
  margin-bottom: 15rpx;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  min-width: 120rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}

.delete-notice {
  text-align: center;
  padding: 15rpx;
  background: #f8d7da;
  border-radius: 8rpx;
  border: 1rpx solid #f5c6cb;
}

.notice-text {
  font-size: 24rpx;
  color: #721c24;
}

/* 睫毛记录表单样式 */
.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4a90e2;
  outline: none;
}

.form-input.readonly {
  background: transparent;
  color: #666;
  border: none;
  padding: 0;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.form-input.readonly::after {
  content: none;
}

.readonly-text {
  display: block;
  color: #666;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 0;
  margin: 0;
}

.confirm-btn {
  background: #07c160 !important;
  color: white !important;
}

.confirm-btn:active {
  background: #06ad56 !important;
}

/* 选择器样式 */
.picker-text {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
}
