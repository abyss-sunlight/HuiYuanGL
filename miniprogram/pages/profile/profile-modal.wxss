/* profile 页面弹窗相关样式 */

/* 新用户注册模态弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.register-modal {
  width: 600rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.modal-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.modal-body {
  padding: 40rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}

/* 模态弹窗中的输入框样式，独立于登录表单 */
.register-modal .form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f9f9f9;
}

.register-modal .form-input:focus {
  border-color: #4a90e2;
  background: white;
}

.radio-group {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.radio-text {
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  padding: 20rpx 40rpx 40rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn.secondary {
  background: #f0f0f0;
  color: #666;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.8;
}

/* 微信新用户注册模态弹窗样式 */
.wx-register-modal {
  width: 650rpx;
  background: white;
  border-radius: 20rpx;
  padding: 0;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.15);
  box-sizing: border-box;
}

/* 微信用户信息展示区域 */
.wx-user-info {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #f8f9ff;
  border-radius: 15rpx;
  margin-bottom: 30rpx;
}

.wx-avatar {
  margin-right: 25rpx;
  flex-shrink: 0;
}

.wx-avatar-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 3rpx solid #e1e8f0;
}

.wx-user-details {
  flex: 1;
  min-width: 0;
}

.wx-nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.wx-info {
  font-size: 24rpx;
  color: #666;
  display: block;
}

/* 微信注册弹窗特殊样式 */
.wx-register-modal .modal-header {
  padding: 30rpx 30rpx 20rpx;
  text-align: center;
}

.wx-register-modal .modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: block;
}

.wx-register-modal .modal-subtitle {
  font-size: 26rpx;
  color: #666;
  display: block;
}

.wx-register-modal .modal-body {
  padding: 0 30rpx 30rpx;
}

.wx-register-modal .modal-footer {
  padding: 20rpx 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.wx-register-modal .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.wx-register-modal .btn.primary {
  background: linear-gradient(135deg, #07c160 0%, #05a047 100%);
  color: white;
}

.wx-register-modal .btn.secondary {
  background: #f0f0f0;
  color: #666;
}

.wx-register-modal .btn:active {
  transform: scale(0.98);
  opacity: 0.8;
}

/* 个人信息编辑模态弹窗样式 */
.personal-info-modal {
  max-width: 600rpx;
  width: 90%;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.personal-info-modal .current-avatar-container {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.personal-info-modal .current-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #f0f0f0;
  transition: all 0.3s ease;
  cursor: pointer;
}

.personal-info-modal .current-avatar:hover {
  border-color: #07c160;
  transform: scale(1.05);
}

.personal-info-modal .current-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.personal-info-modal .current-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.personal-info-modal .placeholder-icon {
  font-size: 50rpx;
  color: #999;
}

.personal-info-modal .avatar-edit-hint {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #07c160;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  white-space: nowrap;
  opacity: 0;
  transition: all 0.3s ease;
}

.personal-info-modal .current-avatar:hover .avatar-edit-hint {
  opacity: 1;
  bottom: 0;
}

.personal-info-modal .avatar-options {
  margin-top: 30rpx;
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.personal-info-modal .avatar-options.show {
  max-height: 500rpx;
  opacity: 1;
}

.personal-info-modal .avatar-item {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
}

.personal-info-modal .avatar-item:hover {
  border-color: #07c160;
  transform: scale(1.1);
}

.personal-info-modal .avatar-item.selected {
  border-color: #07c160;
  transform: scale(1.1);
}

.personal-info-modal .avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.personal-info-modal .avatar-check {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #07c160;
  color: white;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
}

.personal-info-modal .form-group {
  margin-bottom: 30rpx;
}

.personal-info-modal .form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: 500;
}

.personal-info-modal .form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #fafafa;
  transition: border-color 0.3s ease;
}

.personal-info-modal .form-input:focus {
  border-color: #07c160;
  background: white;
}

.personal-info-modal .radio-group {
  display: flex;
  gap: 40rpx;
  margin-top: 15rpx;
}

.personal-info-modal .radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 28rpx;
  color: #333;
}

.personal-info-modal .radio-text {
  margin-top: 4rpx;
}

.personal-info-modal .modal-footer {
  padding: 20rpx 30rpx 30rpx;
  display: flex;
  gap: 20rpx;
}

.personal-info-modal .btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.personal-info-modal .btn.primary {
  background: linear-gradient(135deg, #07c160 0%, #05a047 100%);
  color: white;
}

.personal-info-modal .btn.secondary {
  background: #f0f0f0;
  color: #666;
}

.personal-info-modal .btn:active {
  transform: scale(0.98);
  opacity: 0.8;
}
