<view class="container">
  <view class="filters">
    <view class="filter-row">
      <input class="input" placeholder="手机号（支持模糊）" value="{{filters.phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="filter-row">
      <input class="input" placeholder="姓（支持模糊）" value="{{filters.lastName}}" bindinput="onLastNameInput" />
    </view>

    <view class="filter-row">
      <picker mode="selector" range="{{permissionOptions}}" range-key="label" value="{{permissionIndex}}" bindchange="onPermissionChange">
        <view class="picker">身份：{{permissionOptions[permissionIndex].label}}</view>
      </picker>
    </view>

    <view class="btn-row">
      <button class="btn secondary" bindtap="resetFilters">重置</button>
      <button class="btn primary" bindtap="search">查询</button>
    </view>
    
    <!-- 添加成员按钮 - 仅店长可见 -->
    <view class="btn-row" wx:if="{{userInfo.permissionLevel === 1}}">
      <button class="btn success" bindtap="showAddMemberModal">添加成员</button>
    </view>
    
    <view class="btn-row">
      <button class="btn refresh" bindtap="refreshData">刷新数据</button>
    </view>
  </view>

  <view class="status" wx:if="{{statusText}}">{{statusText}}</view>

  <view class="list" wx:if="{{list.length > 0}}">
    <view class="card" wx:for="{{list}}" wx:key="userId">
      <view class="top">
        <view class="name">{{item.username}}（{{item.lastName}}{{item.gender === 1 ? '男士' : '女士'}}）</view>
        <view class="tag">{{item.permissionName}}</view>
      </view>
      <view class="line">手机号：{{item.phone}}</view>
      <view class="line">性别：{{item.gender === 1 ? '男' : '女'}}</view>

      <view class="member" wx:if="{{item.permissionLevel === 3}}">
        <view class="line">余额：¥{{item.amount || '0.00'}}</view>
        <view class="line">折扣：{{item.discount ? (item.discount * 10) + '折' : '无折扣'}}</view>
      </view>
      
      <!-- 操作按钮区域 -->
      <view class="actions" wx:if="{{userInfo.permissionLevel <= 2}}">
        <!-- 游客卡片按钮 - 员工及以上可以操作 -->
        <view class="action-grid" wx:if="{{item.permissionLevel === 4}}">
          <view class="grid-item">
            <button class="btn primary" bindtap="addEyelashRecord" data-user="{{item}}">添加美睫记录</button>
          </view>
          <view class="grid-item">
            <button class="btn success" bindtap="addRechargeRecord" data-user="{{item}}">充值</button>
          </view>
          <view class="grid-item">
            <button class="btn secondary" bindtap="editMember" data-user="{{item}}">编辑</button>
          </view>
          <view class="grid-item">
            <button class="btn danger" bindtap="deleteMember" data-user="{{item}}">删除</button>
          </view>
        </view>
        
        <!-- 会员卡片按钮 - 员工及以上可以操作 -->
        <view class="action-grid" wx:if="{{item.permissionLevel === 3}}">
          <view class="grid-item">
            <button class="btn primary" bindtap="addEyelashRecord" data-user="{{item}}">添加美睫记录</button>
          </view>
          <view class="grid-item">
            <button class="btn primary" bindtap="addConsumeRecord" data-user="{{item}}">会员消费/充值</button>
          </view>
          <view class="grid-item">
            <button class="btn secondary" bindtap="editMember" data-user="{{item}}">编辑</button>
          </view>
          <view class="grid-item">
            <button class="btn danger" bindtap="deleteMember" data-user="{{item}}">删除</button>
          </view>
        </view>
        
        <!-- 员工卡片按钮 - 只有老板可以操作 -->
        <view class="action-grid" wx:if="{{item.permissionLevel === 2 && userInfo.permissionLevel === 1}}">
          <view class="grid-item">
            <button class="btn secondary" bindtap="editMember" data-user="{{item}}">编辑</button>
          </view>
          <view class="grid-item">
            <button class="btn danger" bindtap="deleteMember" data-user="{{item}}">删除</button>
          </view>
        </view>
        
        <!-- 老板卡片按钮 - 只有老板可以操作自己 -->
        <view class="action-grid" wx:if="{{item.permissionLevel === 1 && userInfo.permissionLevel === 1 && item.userId === userInfo.userId}}">
          <view class="grid-item">
            <button class="btn secondary" bindtap="editMember" data-user="{{item}}">编辑</button>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty" wx:else>
    <view class="empty-text">暂无数据</view>
  </view>
</view>

<!-- 睫毛记录模态弹窗 -->
<view class="modal-overlay" wx:if="{{showEyelashModal}}" bindtap="hideEyelashModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">添加睫毛记录</text>
      <text class="modal-close" bindtap="hideEyelashModal">×</text>
    </view>
    
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">手机号 *</text>
        <text class="readonly-text">{{eyelashForm.phone}}</text>
      </view>
      
      <view class="form-group">
        <text class="form-label">姓氏 *</text>
        <text class="readonly-text">{{eyelashForm.lastName}}</text>
      </view>
      
      <view class="form-group">
        <text class="form-label">款式 *</text>
        <input class="form-input" type="text" placeholder="请输入款式" 
               value="{{eyelashForm.style}}" bindinput="onEyelashStyleInput" />
      </view>
      
      <view class="form-group">
        <text class="form-label">型号 *</text>
        <input class="form-input" type="text" placeholder="请输入型号" 
               value="{{eyelashForm.modelNumber}}" bindinput="onEyelashModelNumberInput" />
      </view>
      
      <view class="form-group">
        <text class="form-label">长度 *</text>
        <input class="form-input" type="number" placeholder="请输入长度(mm)" 
               value="{{eyelashForm.length}}" bindinput="onEyelashLengthInput" />
      </view>
      
      <view class="form-group">
        <text class="form-label">翘度 *</text>
        <input class="form-input" type="text" placeholder="请输入翘度(C/D/J等)" 
               value="{{eyelashForm.curl}}" bindinput="onEyelashCurlInput" />
      </view>
      
      <view class="form-group">
        <text class="form-label">记录日期 *</text>
        <text class="readonly-text">{{eyelashForm.recordDate}}</text>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="hideEyelashModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="submitEyelashForm">确认添加</button>
    </view>
  </view>
</view>

<!-- 消费记录模态弹窗 -->
<view class="modal-overlay" wx:if="{{showConsumeModal}}" bindtap="hideConsumeModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{consumeType === 'recharge' ? '会员充值' : '会员消费'}}</text>
      <text class="modal-close" bindtap="hideConsumeModal">×</text>
    </view>
    
    <view class="modal-body">
      <!-- 手机号（只读） -->
      <view class="form-group">
        <text class="form-label">手机号</text>
        <text class="readonly-text">{{consumeForm.phone}}</text>
      </view>
      
      <!-- 姓氏（只读） -->
      <view class="form-group">
        <text class="form-label">姓氏</text>
        <text class="readonly-text">{{consumeForm.lastName}}</text>
      </view>
      
      <!-- 余额（只读） -->
      <view class="form-group">
        <text class="form-label">余额</text>
        <text class="readonly-text">¥{{consumeForm.balance}}</text>
      </view>
      
      <!-- 金额输入 -->
      <view class="form-group">
        <text class="form-label">{{consumeType === 'recharge' ? '充值金额' : '消费金额'}} *</text>
        <input class="form-input" type="digit" placeholder="请输入金额" 
               value="{{consumeForm.consumeAmount}}" bindinput="onConsumeAmountInput" />
      </view>
      
      <!-- 消费项目选择（仅消费模式） -->
      <view class="form-group" wx:if="{{consumeType === 'consume'}}">
        <text class="form-label">消费项目 *</text>
        <view class="radio-group consume-item-group">
          <view class="radio-item {{consumeForm.consumeItem === '美睫项目' ? 'selected' : ''}}" 
                bindtap="onConsumeItemSelect" data-item="美睫项目">
            <view class="radio-icon {{consumeForm.consumeItem === '美睫项目' ? 'checked' : ''}}"></view>
            <text class="radio-text">美睫项目</text>
          </view>
          <view class="radio-item {{consumeForm.consumeItem === '美甲项目' ? 'selected' : ''}}" 
                bindtap="onConsumeItemSelect" data-item="美甲项目">
            <view class="radio-icon {{consumeForm.consumeItem === '美甲项目' ? 'checked' : ''}}"></view>
            <text class="radio-text">美甲项目</text>
          </view>
        </view>
      </view>
      
      <!-- 消费项目（仅充值模式，固定为会员充值） -->
      <view class="form-group" wx:else>
        <text class="form-label">消费项目</text>
        <text class="readonly-text">会员充值</text>
      </view>
      
      <!-- 消费类型选择（仅消费模式） -->
      <view class="form-group" wx:if="{{consumeType === 'consume'}}">
        <text class="form-label">消费类型 *</text>
        <view class="radio-group consume-type-group">
          <view class="radio-item {{consumeForm.consumeType === '充值' ? 'selected' : ''}}" 
                bindtap="onConsumeTypeSelect" data-type="充值">
            <view class="radio-icon {{consumeForm.consumeType === '充值' ? 'checked' : ''}}"></view>
            <text class="radio-text">充值</text>
          </view>
          <view class="radio-item {{consumeForm.consumeType === '支出' ? 'selected' : ''}}" 
                bindtap="onConsumeTypeSelect" data-type="支出">
            <view class="radio-icon {{consumeForm.consumeType === '支出' ? 'checked' : ''}}"></view>
            <text class="radio-text">支出</text>
          </view>
        </view>
      </view>
      
      <!-- 消费类型（仅充值模式，固定为充值） -->
      <view class="form-group" wx:else>
        <text class="form-label">消费类型</text>
        <text class="readonly-text">充值</text>
      </view>
      
      <!-- 日期（只读） -->
      <view class="form-group">
        <text class="form-label">日期</text>
        <text class="readonly-text">{{consumeForm.consumeDate}}</text>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="hideConsumeModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="submitConsumeForm">确认{{consumeType === 'recharge' ? '充值' : '消费'}}</button>
    </view>
  </view>
</view>

<!-- 添加成员模态弹窗 -->
<view class="modal-overlay" wx:if="{{showAddMemberModal}}" bindtap="hideAddMemberModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">添加成员</text>
      <text class="modal-close" bindtap="hideAddMemberModal">×</text>
    </view>
    
    <view class="modal-body">
      <!-- 权限等级 -->
      <view class="form-group">
        <text class="form-label">权限等级 *</text>
        <view class="radio-group permission-radio-group">
          <view class="radio-item {{addMemberForm.permissionLevel === 2 ? 'selected' : ''}}" 
                bindtap="onPermissionSelect" data-permission="2">
            <view class="radio-icon {{addMemberForm.permissionLevel === 2 ? 'checked' : ''}}"></view>
            <text class="radio-text">员工</text>
          </view>
          <view class="radio-item {{addMemberForm.permissionLevel === 3 ? 'selected' : ''}}" 
                bindtap="onPermissionSelect" data-permission="3">
            <view class="radio-icon {{addMemberForm.permissionLevel === 3 ? 'checked' : ''}}"></view>
            <text class="radio-text">会员</text>
          </view>
          <view class="radio-item {{addMemberForm.permissionLevel === 4 ? 'selected' : ''}}" 
                bindtap="onPermissionSelect" data-permission="4">
            <view class="radio-icon {{addMemberForm.permissionLevel === 4 ? 'checked' : ''}}"></view>
            <text class="radio-text">游客</text>
          </view>
        </view>
        <view class="permission-hint">提示：店长权限不允许创建</view>
      </view>
      
      <!-- 手机号 -->
      <view class="form-group">
        <text class="form-label">手机号 *</text>
        <input class="form-input" type="number" placeholder="请输入手机号" 
               value="{{addMemberForm.phone}}" bindinput="onAddMemberPhoneInput" maxlength="11" />
      </view>
      
      <!-- 姓氏 -->
      <view class="form-group">
        <text class="form-label">姓氏 *</text>
        <input class="form-input" type="text" placeholder="请输入姓氏" 
               value="{{addMemberForm.lastName}}" bindinput="onAddMemberLastNameInput" />
      </view>
      
      <!-- 用户名（可选） -->
      <view class="form-group">
        <text class="form-label">用户名</text>
        <input class="form-input" type="text" placeholder="留空将自动生成" 
               value="{{addMemberForm.username}}" bindinput="onUsernameInput" />
      </view>
      
      <!-- 头像URL（可选） -->
      <view class="form-group">
        <text class="form-label">头像</text>
        <view class="current-avatar-container">
          <view class="current-avatar" bindtap="toggleAvatarSelector">
            <image wx:if="{{addMemberForm.avatarUrl}}" 
                   class="current-avatar-img" 
                   src="{{addMemberForm.avatarUrl}}" 
                   mode="aspectFill" />
            <view wx:else class="current-avatar-placeholder">
              <text class="placeholder-icon">👤</text>
            </view>
            <view class="avatar-edit-hint">点击选择头像</view>
          </view>
        </view>
        
        <!-- 头像选择器 -->
        <view class="avatar-options {{showAvatarOptions ? 'show' : ''}}" wx:if="{{showAvatarOptions}}">
          <view class="avatar-item" wx:for="{{avatarOptions}}" wx:key="index" 
                bindtap="selectAvatar" data-index="{{index}}">
            <image class="avatar-img {{addMemberForm.avatarUrl === item ? 'selected' : ''}}" 
                   src="{{item}}" mode="aspectFill" />
            <view class="avatar-check" wx:if="{{addMemberForm.avatarUrl === item}}">✓</view>
          </view>
        </view>
      </view>
      
      <!-- 性别 -->
      <view class="form-group">
        <text class="form-label">性别 *</text>
        <view class="radio-group">
          <view class="radio-item {{addMemberForm.gender === 1 ? 'selected' : ''}}" 
                bindtap="onGenderSelect" data-gender="1">
            <view class="radio-icon {{addMemberForm.gender === 1 ? 'checked' : ''}}"></view>
            <text class="radio-text">男</text>
          </view>
          <view class="radio-item {{addMemberForm.gender === 2 ? 'selected' : ''}}" 
                bindtap="onGenderSelect" data-gender="2">
            <view class="radio-icon {{addMemberForm.gender === 2 ? 'checked' : ''}}"></view>
            <text class="radio-text">女</text>
          </view>
        </view>
      </view>
      
      <!-- 会员专属字段 -->
      <view wx:if="{{addMemberForm.permissionLevel === 3}}">
        <!-- 初始余额 -->
        <view class="form-group">
          <text class="form-label">初始余额</text>
          <input class="form-input" type="digit" placeholder="请输入初始余额（可选）" 
                 value="{{addMemberForm.amount}}" bindinput="onAmountInput" />
        </view>
        
        <!-- 折扣率 -->
        <view class="form-group">
          <text class="form-label">折扣率</text>
          <input class="form-input" type="digit" placeholder="请输入折扣率，如0.95表示95折（可选）" 
                 value="{{addMemberForm.discount}}" bindinput="onDiscountInput" />
        </view>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="hideAddMemberModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="submitAddMemberForm">确认添加</button>
    </view>
  </view>
</view>

<!-- 成员编辑模态弹窗 -->
<view class="modal-overlay" wx:if="{{showEditMemberModal}}" bindtap="hideEditMemberModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">编辑成员</text>
      <text class="modal-close" bindtap="hideEditMemberModal">×</text>
    </view>
    
    <view class="modal-body">
      <!-- 用户头像 -->
      <view class="user-avatar-section">
        <image wx:if="{{editMemberForm.avatarUrl}}" 
               class="user-avatar" 
               src="{{editMemberForm.avatarUrl}}" 
               mode="aspectFill" />
        <view wx:else class="user-avatar-placeholder">
          <text class="avatar-placeholder-icon">👤</text>
        </view>
      </view>
      
      <!-- 用户基本信息 -->
      <view class="user-info-section">
        <view class="info-row">
          <text class="info-label">用户昵称：</text>
          <text class="info-value">{{editMemberForm.username}}</text>
        </view>
        
        <view class="info-row">
          <text class="info-label">用户角色：</text>
          <text class="info-value">{{editMemberForm.permissionName}}</text>
        </view>
        
        <view class="info-row">
          <text class="info-label">联系方式：</text>
          <text class="info-value">{{editMemberForm.phone}}</text>
        </view>
        
        <view class="info-row">
          <text class="info-label">注册时间：</text>
          <text class="info-value">{{editMemberForm.createdAt}}</text>
        </view>
        
        <view class="info-row">
          <text class="info-label">最后活跃：</text>
          <text class="info-value">{{editMemberForm.updatedAt}}</text>
        </view>
      </view>
      
      <!-- 账户状态控制 -->
      <view class="status-section">
        <view class="status-row">
          <text class="status-label">账户状态</text>
          <switch class="status-switch" 
                  checked="{{editMemberForm.status === 0}}" 
                  bindchange="onStatusChange" 
                  color="#07c160" />
          <text class="status-text">{{editMemberForm.status === 0 ? '正常' : '禁用'}}</text>
        </view>
        <view class="status-hint">{{editMemberForm.status === 0 ? '用户可正常使用系统' : '用户已被禁用，无法登录'}}</view>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="modal-btn cancel-btn" bindtap="hideEditMemberModal">取消</button>
      <button class="modal-btn confirm-btn" bindtap="saveMemberChanges">保存更改</button>
    </view>
  </view>
</view>
