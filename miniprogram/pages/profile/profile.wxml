<view class="container">
  <!-- 未登录状态 -->
  <view wx:if="{{!isLoggedIn}}" class="login-section">
    <view class="login-header">
      <view class="avatar-placeholder">
        <text class="avatar-text">👤</text>
      </view>
      <view class="login-title">登录账户</view>
      <view class="login-desc">请选择登录方式以继续使用</view>
    </view>

    <!-- 登录方式选择 -->
    <view class="login-methods">
      <!-- 短信登录 -->
      <view class="method-item" bindtap="showSmsLogin">
        <view class="icon sms-icon">📱</view>
        <view class="method-name">短信登录/注册</view>
        <view class="method-desc">新用户自动注册，老用户直接登录</view>
      </view>

      <!-- 密码登录 -->
      <view class="method-item" bindtap="showPasswordLogin">
        <view class="icon password-icon">🔐</view>
        <view class="method-name">密码登录</view>
        <view class="method-desc">使用手机号密码登录</view>
      </view>
    </view>

    <!-- 短信登录表单 -->
    <view class="login-form" wx:if="{{showSmsForm}}">
      <view class="form-title">短信登录/注册</view>
      <view class="form-tip">首次使用将自动创建账户</view>
      <view class="form-item">
        <input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" bindinput="onSmsPhoneInput" value="{{smsPhone}}" />
      </view>
      <view class="form-item">
        <input class="form-input code-input" placeholder="请输入验证码" type="number" maxlength="6" bindinput="onSmsCodeInput" value="{{smsCode}}" />
        <button class="code-btn" bindtap="sendSmsCode" disabled="{{smsCodeSending}}">
          {{smsCodeText}}
        </button>
      </view>
      <button class="login-btn" bindtap="smsLoginSubmit" loading="{{smsLogging}}">
        登录/注册
      </button>
      <button class="back-btn" bindtap="hideSmsLogin">关闭</button>
    </view>

    <!-- 密码登录表单 -->
    <view class="login-form" wx:if="{{showPasswordForm}}">
      <view class="form-title">密码登录</view>
      <view class="form-item">
        <input class="form-input" placeholder="请输入手机号" type="number" maxlength="11" bindinput="onPasswordPhoneInput" value="{{passwordPhone}}" />
      </view>
      <view class="form-item">
        <input class="form-input" placeholder="请输入密码" password="{{!showPassword}}" bindinput="onPasswordInput" value="{{password}}" />
        <text class="eye-icon" bindtap="togglePassword">{{showPassword ? '✕' : '○'}}</text>
      </view>
      <button class="login-btn" bindtap="passwordLoginSubmit" loading="{{passwordLogging}}">
        登录
      </button>
      <button class="back-btn" bindtap="hidePasswordLogin">关闭</button>
    </view>

    <!-- 测试账号提示 -->
    <view class="test-accounts">
      <view class="test-title">测试账号</view>
      <view class="account-item">
        <text>店长：13800138001 / 123456</text>
      </view>
      <view class="account-item">
        <text>员工：13800138002 / 123456</text>
      </view>
      <view class="account-item">
        <text>会员：13800138004 / 123456</text>
      </view>
      <view class="account-item">
        <text>短信验证码：123456</text>
      </view>
    </view>
  </view>

  <!-- 已登录状态 -->
  <view wx:else class="user-section">
    <view class="user-card">
      <view class="user-avatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img" />
        <view wx:else class="avatar-placeholder">{{userInfo.username.charAt(0)}}</view>
      </view>
      <view class="user-details">
        <view class="user-name">{{userInfo.username}}（{{userInfo.lastName}}{{userInfo.gender === 1 ? '男士' : '女士'}}）</view>
        <view class="user-meta">
          <view class="user-permission">{{userInfo.permissionName}}</view>
          <view class="user-phone">{{userInfo.phone}}</view>
        </view>
        <!-- 会员专属信息 -->
        <view wx:if="{{userInfo.permissionLevel === 3}}" class="member-info">
          <view class="member-item">会员号：{{userInfo.memberNo || '未设置'}}</view>
          <view class="member-item">余额：¥{{userInfo.amount || '0.00'}}</view>
          <view class="member-item">折扣：{{userInfo.discount ? (userInfo.discount * 10) + '折' : '无折扣'}}</view>
        </view>
      </view>
    </view>

    <view class="menu-list">
      <view class="menu-item" bindtap="viewUserInfo">
        <view class="menu-icon">👤</view>
        <view class="menu-title">个人信息</view>
        <view class="menu-arrow">></view>
      </view>

      <view class="menu-item" bindtap="goToSetPassword">
        <view class="menu-icon">🔑</view>
        <view class="menu-title">设置密码</view>
        <view class="menu-arrow">></view>
      </view>

      <view class="menu-item" bindtap="viewSettings">
        <view class="menu-icon">⚙️</view>
        <view class="menu-title">设置</view>
        <view class="menu-arrow">></view>
      </view>

      <view class="menu-item" bindtap="viewHelp">
        <view class="menu-icon">❓</view>
        <view class="menu-title">帮助与反馈</view>
        <view class="menu-arrow">></view>
      </view>

      <view class="menu-item" bindtap="viewAbout">
        <view class="menu-icon">ℹ️</view>
        <view class="menu-title">关于</view>
        <view class="menu-arrow">></view>
      </view>
    </view>

    <!-- 测试账号提示 -->
    <view class="test-accounts" wx:if="{{!isLoggedIn}}">
      <view class="test-title">测试账号</view>
      <view class="account-item">
        <text>店长：13800138001 / 123456</text>
      </view>
      <view class="account-item">
        <text>员工：13800138002 / 123456</text>
      </view>
      <view class="account-item">
        <text>会员：13800138004 / 123456</text>
      </view>
      <view class="account-item">
        <text>短信验证码：123456</text>
      </view>
    </view>

    <button class="logout-btn" bindtap="logout" wx:if="{{isLoggedIn}}">退出登录</button>
  </view>
</view>

<!-- 新用户注册模态弹窗 -->
<view class="modal-overlay" wx:if="{{showRegisterModal}}">
  <view class="modal-content register-modal">
    <view class="modal-header">
      <text class="modal-title">完善个人信息</text>
      <text class="modal-subtitle">请补充您的姓名和性别</text>
    </view>
    
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">姓氏 *</text>
        <input class="form-input" placeholder="请输入您的姓氏" 
               bindinput="onRegisterLastNameInput" 
               value="{{registerForm.lastName}}" 
               maxlength="10" />
      </view>
      
      <view class="form-group">
        <text class="form-label">性别 *</text>
        <radio-group class="radio-group" bindchange="onGenderChange">
          <label class="radio-item" wx:for="{{[{value: 1, name: '男'}, {value: 2, name: '女'}]}}" wx:key="value">
            <radio value="{{item.value}}" checked="{{registerForm.gender === item.value}}" />
            <text class="radio-text">{{item.name}}</text>
          </label>
        </radio-group>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="btn secondary" bindtap="cancelRegister">取消</button>
      <button class="btn primary" bindtap="submitRegister">确认提交</button>
    </view>
  </view>
</view>
