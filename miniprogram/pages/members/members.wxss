.container {
  padding: 30rpx;
  background: #f7f7f7;
  min-height: 100vh;
  box-sizing: border-box;
}

.filters {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.filter-row {
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.picker {
  height: 80rpx;
  display: flex;
  align-items: center;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.btn-row {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.primary {
  background: #4a90e2;
  color: #fff;
}

.secondary {
  background: #f0f0f0;
  color: #333;
}

.success {
  background: #2ed573;
  color: white;
}

.refresh {
  background: #28a745;
  color: #fff;
}

/* 操作按钮区域样式 */
.actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

/* 当只有一个按钮时，占满宽度 */
.action-grid.single-button {
  grid-template-columns: 1fr;
}

/* 两个按钮时的特殊布局 */
.action-grid.two-buttons {
  grid-template-columns: 1fr 1fr;
}

.grid-item {
  display: flex;
}

.grid-item .btn {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  height: auto;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status {
  color: #666;
  font-size: 26rpx;
  padding: 10rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  font-size: 24rpx;
  color: #4a90e2;
  padding-left: 16rpx;
  flex-shrink: 0;
}

.line {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.member {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 模态弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  background: #fff;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #07c160 !important;
  color: white !important;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4a90e2;
  outline: none;
}

.form-input.readonly {
  background: transparent;
  color: #666;
  border: none;
  padding: 0;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.form-input.readonly::after {
  content: none;
}

.readonly-text {
  display: block;
  color: #666;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 0;
  margin: 0;
}

/* 选择器样式 */
.picker-text {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
}

/* 添加成员功能特定样式 */
.btn.success {
  background: #2ed573;
  color: white;
  border: none;
}

.btn.success:hover {
  background: #26c965;
}

/* 表单验证提示样式 */
.form-group.error .form-input {
  border-color: #ff4757;
  background: #fff5f5;
}

.form-group.error .form-label {
  color: #ff4757;
}

/* 会员专属字段样式 */
.member-fields {
  background: #f8f9ff;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-top: 20rpx;
  border-left: 4rpx solid #4a90e2;
}

.member-fields .form-label {
  color: #4a90e2;
  font-size: 26rpx;
}

/* 响应式优化 */
@media (max-width: 750rpx) {
  .modal-content {
    width: 95%;
    margin: 40rpx auto;
  }
  
  .action-grid {
    grid-template-columns: 1fr;
    gap: 10rpx;
  }
}

/* 加载状态样式 */
.btn.loading {
  opacity: 0.7;
  pointer-events: none;
}

.btn.loading::after {
  content: '';
  display: inline-block;
  width: 20rpx;
  height: 20rpx;
  border: 2rpx solid #fff;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-left: 10rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 头像选择器样式 - 与个人信息弹窗保持一致 */
.current-avatar-container {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.current-avatar {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid #f0f0f0;
  transition: all 0.3s ease;
  cursor: pointer;
}

.current-avatar:hover {
  border-color: #07c160;
  transform: scale(1.05);
}

.current-avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.current-avatar-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-icon {
  font-size: 50rpx;
  color: #999;
}

.avatar-edit-hint {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: #07c160;
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  white-space: nowrap;
  opacity: 0;
  transition: all 0.3s ease;
}

.current-avatar:hover .avatar-edit-hint {
  opacity: 1;
  bottom: 0;
}

.avatar-options {
  margin-top: 30rpx;
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.avatar-options.show {
  max-height: 500rpx;
  opacity: 1;
}

.avatar-item {
  position: relative;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
}

.avatar-item:hover {
  border-color: #07c160;
  transform: scale(1.1);
}

.avatar-item.selected {
  border-color: #07c160;
  transform: scale(1.1);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
}

.avatar-check {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #07c160;
  color: white;
  width: 30rpx;
  height: 30rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
}

/* 单选按钮样式 */
.radio-group {
  display: flex;
  gap: 40rpx;
  margin-top: 10rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid #e0e0e0;
  background: #fafafa;
  transition: all 0.3s ease;
  cursor: pointer;
  flex: 1;
  justify-content: center;
}

.radio-item:hover {
  border-color: #4a90e2;
  background: #f0f8ff;
}

.radio-item.selected {
  border-color: #07c160;
  background: #f0fff4;
  box-shadow: 0 2rpx 8rpx rgba(7, 193, 96, 0.2);
}

.radio-icon {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  background: white;
  position: relative;
  transition: all 0.3s ease;
}

.radio-icon.checked {
  border-color: #07c160;
  background: #07c160;
}

.radio-icon.checked::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: white;
}

.radio-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  transition: color 0.3s ease;
}

.radio-item.selected .radio-text {
  color: #07c160;
  font-weight: 600;
}

/* 权限单选按钮特殊样式 */
.permission-radio-group {
  gap: 20rpx;
}

.permission-radio-group .radio-item {
  flex: 1;
  min-width: 0;
}

/* 消费项目单选按钮特殊样式 */
.consume-item-group {
  gap: 20rpx;
}

.consume-item-group .radio-item {
  flex: 1;
  min-width: 0;
}

/* 消费类型单选按钮特殊样式 */
.consume-type-group {
  gap: 20rpx;
}

.consume-type-group .radio-item {
  flex: 1;
  min-width: 0;
}

.permission-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  text-align: center;
  font-style: italic;
}

/* 响应式优化 */
@media (max-width: 750rpx) {
  .radio-group {
    gap: 20rpx;
  }
  
  .permission-radio-group,
  .consume-item-group,
  .consume-type-group {
    gap: 15rpx;
  }
  
  .radio-item {
    padding: 12rpx 16rpx;
    font-size: 26rpx;
  }
  
  .radio-text {
    font-size: 26rpx;
  }
  
  .permission-hint {
    font-size: 22rpx;
  }
}

@media (max-width: 600rpx) {
  .permission-radio-group,
  .consume-item-group,
  .consume-type-group {
    flex-direction: column;
    gap: 12rpx;
  }
  
  .permission-radio-group .radio-item,
  .consume-item-group .radio-item,
  .consume-type-group .radio-item {
    flex: none;
  }
}

/* 成员编辑弹窗样式 */
.user-avatar-section {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 4rpx solid #f0f0f0;
}

.user-avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #f0f0f0;
}

.avatar-placeholder-icon {
  font-size: 50rpx;
  color: #999;
}

.user-info-section {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  min-width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.status-section {
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.status-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.status-switch {
  transform: scale(1.2);
}

.status-text {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.status-hint {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  padding-left: 20rpx;
}

/* 状态颜色优化 */
.status-section .status-text {
  color: #07c160;
}

.status-section[data-status="disabled"] .status-text {
  color: #ff4757;
}

/* 响应式优化 - 编辑弹窗 */
@media (max-width: 750rpx) {
  .user-avatar,
  .user-avatar-placeholder {
    width: 100rpx;
    height: 100rpx;
  }
  
  .avatar-placeholder-icon {
    font-size: 40rpx;
  }
  
  .info-row {
    flex-direction: column;
    align-items: flex-start;
    gap: 8rpx;
  }
  
  .info-label {
    min-width: auto;
  }
  
  .status-row {
    flex-wrap: wrap;
    gap: 15rpx;
  }
}
