/* records 页面：布局/列表/搜索等基础样式（下半部分） */

/* 搜索区域样式 - 按照成员列表样式 */
.filters {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.filter-row {
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.picker {
  height: 80rpx;
  display: flex;
  align-items: center;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.btn-row {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.primary {
  background: #4a90e2;
  color: #fff;
}

.secondary {
  background: #f0f0f0;
  color: #333;
}

/* 状态显示 */
.status {
  color: #666;
  font-size: 26rpx;
  padding: 10rpx 0;
}

/* 列表样式 - 按照成员列表样式 */
.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  font-size: 24rpx;
  color: #4a90e2;
  padding-left: 16rpx;
  flex-shrink: 0;
}

.line {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn-column {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.btn-column .btn {
  width: 100%;
}

.danger {
  background: #dc3545;
  color: #fff;
}

.danger:active {
  background: #c82333;
}

/* 空状态显示 */
.empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.clear-btn:active {
  background: #5a6268;
}

.search-btn {
  flex: 2;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 16rpx 0;
  border: none;
}

.search-btn:active {
  background: linear-gradient(135deg, #5a6fd8 0%, #6a4190 100%);
}

/* 记录卡片样式 */
.record-card {
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 15rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.customer-info {
  display: flex;
  flex-direction: column;
}

.customer-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.customer-phone {
  font-size: 24rpx;
  color: #666;
}

.record-date {
  font-size: 24rpx;
  color: #999;
}

.record-details {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.detail-item {
  width: 50%;
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
  box-sizing: border-box;
  padding-right: 10rpx;
}

.detail-label {
  font-size: 26rpx;
  color: #666;
  margin-right: 10rpx;
  min-width: 80rpx;
}

.detail-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* 翘度样式 */
.curl-C { color: #4a90e2; font-weight: bold; }
.curl-D { color: #ff6b35; font-weight: bold; }
.curl-J { color: #07c160; font-weight: bold; }

.record-footer {
  padding-top: 15rpx;
  border-top: 1rpx solid #f0f0f0;
}

.create-time {
  font-size: 22rpx;
  color: #999;
}
