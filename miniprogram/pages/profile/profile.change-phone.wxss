/* 手机号修改弹窗样式 */
.change-phone-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.change-phone-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.change-phone-content {
  position: relative;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow-y: auto;
  animation: modalFadeIn 0.3s ease-out;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.change-phone-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.change-phone-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.change-phone-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6b7280;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
}

.change-phone-close::after {
  border: none;
}

/* 步骤指示器样式 */
.step-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 30rpx;
}

.step-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #9ca3af;
  transition: color 0.3s ease;
}

.step-item.active {
  color: #007aff;
}

.step-item.completed {
  color: #007aff;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e5e7eb;
  color: #9ca3af;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 12rpx;
  transition: all 0.3s ease;
}

.step-item.active .step-number {
  background: #007aff;
  color: #ffffff;
}

.step-item.completed .step-number {
  background: #007aff;
  color: #ffffff;
}

.step-line {
  width: 80rpx;
  height: 2rpx;
  background: #e5e7eb;
  margin: 0 20rpx;
  transition: background 0.3s ease;
}

.step-item.completed .step-line {
  background: #007aff;
}

.change-phone-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 28rpx;
  text-align: center;
}

.change-phone-form .form-item {
  margin-bottom: 22rpx;
}

.change-phone-form .label {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 10rpx;
}

.change-phone-form .input {
  background: #f3f4f6;
  border-radius: 14rpx;
  height: 76rpx;
  padding: 0 22rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.change-phone-form .input:disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

.change-phone-form .code-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.change-phone-form .code-input {
  flex: 1;
}

/* 验证码按钮样式 */
.change-phone-form .code-btn {
  width: 220rpx !important;
  height: 76rpx !important;
  line-height: 76rpx !important;
  font-size: 26rpx !important;
  border-radius: 14rpx !important;
  background: #111827 !important;
  color: #ffffff !important;
  padding: 0 !important;
  margin: 0 !important;
  box-sizing: border-box !important;
  position: relative !important;
  right: auto !important;
  top: auto !important;
  transform: none !important;
  z-index: auto !important;
  cursor: default !important;
}

.change-phone-form .code-btn[disabled] {
  background: #9ca3af !important;
  color: #ffffff !important;
}

.change-phone-form .code-btn::after {
  border: none;
}

/* 步骤切换按钮样式 */
.change-phone-form .step-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #007aff;
  color: #ffffff;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

.change-phone-form .step-btn.secondary {
  background: #f3f4f6;
  color: #374151;
  margin-right: 16rpx;
}

.change-phone-form .step-btn::after {
  border: none;
}

.change-phone-form .button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 10rpx;
}

.change-phone-form .button-row .step-btn {
  flex: 1;
  margin-top: 0;
}

/* 原手机号步骤样式 */
.step-1-content {
  display: block;
}

.step-2-content {
  display: none;
}

.current-step-2 .step-1-content {
  display: none;
}

.current-step-2 .step-2-content {
  display: block;
}

/* 成功状态样式 */
.success-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 40rpx auto;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 60rpx;
}

.success-message {
  text-align: center;
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 40rpx;
}
