/* 密码设置弹窗样式 */
.set-password-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.set-password-modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
}

.set-password-content {
  position: relative;
  width: 90%;
  max-width: 600rpx;
  max-height: 80vh;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
  overflow-y: auto;
  animation: modalFadeIn 0.3s ease-out;
}

@keyframes modalFadeIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.set-password-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.set-password-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.set-password-close {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #6b7280;
  background: none;
  border: none;
  padding: 0;
  margin: 0;
}

.set-password-close::after {
  border: none;
}

.set-password-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 28rpx;
}

.set-password-form .form-item {
  margin-bottom: 22rpx;
}

.set-password-form .label {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 10rpx;
}

.set-password-form .input {
  background: #f3f4f6;
  border-radius: 14rpx;
  height: 76rpx;
  padding: 0 22rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.set-password-form .code-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.set-password-form .code-input {
  flex: 1;
}

/* 密码设置弹窗样式 - 使用更高优先级选择器 */
.set-password-form .code-btn {
  width: 220rpx !important;
  height: 76rpx !important;
  line-height: 76rpx !important;
  font-size: 26rpx !important;
  border-radius: 14rpx !important;
  background: #111827 !important;
  color: #ffffff !important;
  padding: 0 !important;
  margin: 0 !important;
  box-sizing: border-box !important;
  position: relative !important;
  right: auto !important;
  top: auto !important;
  transform: none !important;
  z-index: auto !important;
  cursor: default !important;
}

.set-password-form .code-btn[disabled] {
  background: #9ca3af;
  color: #ffffff;
}

.set-password-form .code-btn::after {
  border: none;
}

/* 密码输入框容器 */
.set-password-form .password-input-container {
  position: relative;
  display: flex;
  align-items: center;
}

.set-password-form .password-input {
  flex: 1;
  padding-right: 80rpx;
}

.set-password-form .password-eye-icon {
  position: absolute;
  right: 25rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #666;
  padding: 10rpx;
  cursor: pointer;
  transition: color 0.2s ease;
}

.set-password-form .password-eye-icon:active {
  color: #111827;
  transform: translateY(-50%) scale(0.9);
}

.set-password-form .submit-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #007aff;
  color: #ffffff;
  font-size: 30rpx;
  text-align: center;
  box-sizing: border-box;
}

.set-password-form .submit-btn::after {
  border: none;
}
