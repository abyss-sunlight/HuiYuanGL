<view class="container">
  <view class="card">
    <view class="title">设置/重置密码</view>
    <view class="desc">通过短信验证码设置新密码</view>

    <view class="form">
      <view class="form-item">
        <view class="label">手机号</view>
        <input
          class="input"
          placeholder="请输入手机号"
          type="number"
          maxlength="11"
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>

      <view class="form-item">
        <view class="label">验证码</view>
        <view class="code-row">
          <input
            class="input code-input"
            placeholder="请输入6位验证码"
            type="number"
            maxlength="6"
            value="{{code}}"
            bindinput="onCodeInput"
          />
          <button class="code-btn" bindtap="sendSmsCode" disabled="{{codeSending}}">{{codeText}}</button>
        </view>
      </view>

      <view class="form-item">
        <view class="label">新密码</view>
        <input
          class="input"
          placeholder="至少6位"
          password
          value="{{newPassword}}"
          bindinput="onNewPasswordInput"
        />
      </view>

      <button class="submit-btn" bindtap="submit" loading="{{submitting}}">确认设置</button>
    </view>
  </view>
</view>
