.container {
  padding: 30rpx;
  background: #f7f7f7;
  min-height: 100vh;
  box-sizing: border-box;
}

.filters {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 20rpx;
}

.filter-row {
  margin-bottom: 20rpx;
}

.input {
  width: 100%;
  height: 80rpx;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.picker {
  height: 80rpx;
  display: flex;
  align-items: center;
  background: #f6f7fb;
  border-radius: 12rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #333;
}

.btn-row {
  display: flex;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}

.primary {
  background: #4a90e2;
  color: #fff;
}

.secondary {
  background: #f0f0f0;
  color: #333;
}

.success {
  background: #2ed573;
  color: white;
}

.refresh {
  background: #28a745;
  color: #fff;
}

/* 操作按钮区域样式 */
.actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15rpx;
}

/* 当只有一个按钮时，占满宽度 */
.action-grid.single-button {
  grid-template-columns: 1fr;
}

/* 两个按钮时的特殊布局 */
.action-grid.two-buttons {
  grid-template-columns: 1fr 1fr;
}

.grid-item {
  display: flex;
}

.grid-item .btn {
  flex: 1;
  font-size: 24rpx;
  padding: 8rpx 12rpx;
  height: auto;
  min-height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.status {
  color: #666;
  font-size: 26rpx;
  padding: 10rpx 0;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag {
  font-size: 24rpx;
  color: #4a90e2;
  padding-left: 16rpx;
  flex-shrink: 0;
}

.line {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.member {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 模态弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  padding: 40rpx 20rpx;
  box-sizing: border-box;
}

.modal-content {
  background: #fff;
  border-radius: 16rpx;
  width: 90%;
  max-width: 600rpx;
  max-height: 85vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  background: #f5f5f5;
}

.modal-body {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
  min-height: 0;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 1rpx solid #f0f0f0;
  flex-shrink: 0;
  background: #fff;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  border: none;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.confirm-btn {
  background: #07c160 !important;
  color: white !important;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4a90e2;
  outline: none;
}

.form-input.readonly {
  background: transparent;
  color: #666;
  border: none;
  padding: 0;
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.form-input.readonly::after {
  content: none;
}

.readonly-text {
  display: block;
  color: #666;
  font-size: 28rpx;
  line-height: 1.5;
  padding: 0;
  margin: 0;
}

/* 选择器样式 */
.picker-text {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  background: #fff;
  box-sizing: border-box;
}
