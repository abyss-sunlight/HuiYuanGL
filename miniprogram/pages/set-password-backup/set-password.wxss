.container {
  padding: 24rpx;
  background: #f7f7f7;
  min-height: 100vh;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 28rpx;
}

.form-item {
  margin-bottom: 22rpx;
}

.label {
  font-size: 26rpx;
  color: #374151;
  margin-bottom: 10rpx;
}

.input {
  background: #f3f4f6;
  border-radius: 14rpx;
  height: 76rpx;
  padding: 0 22rpx;
  line-height: 76rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.code-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.code-input {
  flex: 1;
}

.code-btn {
  width: 220rpx;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 26rpx;
  border-radius: 14rpx;
  background: #111827;
  color: #ffffff;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.code-btn[disabled] {
  background: #9ca3af;
  color: #ffffff;
}

.submit-btn {
  margin-top: 10rpx;
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 16rpx;
  background: #007aff;
  color: #ffffff;
  font-size: 30rpx;
}
