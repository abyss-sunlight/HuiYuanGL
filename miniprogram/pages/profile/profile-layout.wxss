/* profile 页面样式（上半部分：基础布局 + 登录区） */

.container {
  padding: 40rpx;
  background: #f7f7f7;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 登录区域样式 */
.login-section {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  margin: -40rpx;
  padding: 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.login-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
  color: white;
  flex-shrink: 0;
}

.avatar-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30rpx;
}

.avatar-text {
  font-size: 60rpx;
}

.login-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.login-desc {
  font-size: 28rpx;
  opacity: 0.8;
  line-height: 1.4;
}

.login-methods {
  margin-bottom: 40rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.method-item {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.2s;
  box-sizing: border-box;
}

.method-item:active {
  transform: scale(0.98);
}

.icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 25rpx;
  flex-shrink: 0;
}

.wechat-icon {
  background: #07c160;
}

.sms-icon {
  background: #ff6b35;
}

.password-icon {
  background: #4a90e2;
}

.method-name {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.2;
}

.method-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.3;
}

.login-form {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  padding: 50rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  flex-shrink: 0;
}

.form-title {
  text-align: center;
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.form-tip {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
  text-align: center;
  padding: 10rpx 20rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  border-left: 4rpx solid #4a90e2;
}

.form-item {
  margin-bottom: 25rpx;
  position: relative;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 25rpx;
  font-size: 28rpx;
  background: #f8f8f8;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #4a90e2;
  background: white;
}

.code-input {
  padding-right: 180rpx;
}

.code-btn {
  position: absolute;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 160rpx;
  height: 60rpx;
  font-size: 22rpx;
  background: #4a90e2;
  color: white;
  border-radius: 8rpx;
  line-height: 60rpx;
  z-index: 10;
  cursor: pointer;
}

.eye-icon {
  position: absolute;
  z-index: 2;
  right: 25rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  color: #666;
  padding: 10rpx;
  border-radius: 50%;
  transition: all 0.2s ease;
  cursor: pointer;
}

.eye-icon:active {
  background: rgba(74, 144, 226, 0.1);
  transform: translateY(-50%) scale(0.9);
}

.login-btn {
  width: 100%;
  height: 80rpx;
  background: #4a90e2;
  color: white;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  border: none;
}

.back-btn {
  width: 100%;
  height: 80rpx;
  background: #f0f0f0;
  color: #666;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
}

.test-accounts {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 25rpx;
  margin-bottom: 40rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.test-title {
  text-align: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.account-item {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  text-align: center;
  line-height: 1.3;
}

/* 新用户注册模态弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.register-modal {
  width: 600rpx;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.2);
}

.modal-header {
  padding: 40rpx 40rpx 20rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.modal-subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  display: block;
}

.modal-body {
  padding: 40rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 15rpx;
  font-weight: bold;
}

/* 模态弹窗中的输入框样式，独立于登录表单 */
.register-modal .form-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f9f9f9;
}

.register-modal .form-input:focus {
  border-color: #4a90e2;
  background: white;
}

.radio-group {
  display: flex;
  gap: 40rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.radio-text {
  font-size: 28rpx;
  color: #333;
}

.modal-footer {
  padding: 20rpx 40rpx 40rpx;
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn.secondary {
  background: #f0f0f0;
  color: #666;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.8;
}
