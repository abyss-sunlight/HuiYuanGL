<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-title">充值折扣管理</view>
    <view class="header-desc">设置不同充值金额对应的折扣</view>
  </view>

  <!-- 添加折扣按钮 -->
  <view class="add-section">
    <button class="add-btn" bindtap="showAddDiscountModal">添加折扣规则</button>
  </view>

  <!-- 折扣列表 -->
  <view class="discount-list">
    <view class="list-header">
      <text class="header-text">当前折扣规则</text>
      <text class="header-count">共 {{discountList.length}} 条</text>
    </view>
    
    <view class="discount-item" wx:for="{{discountList}}" wx:key="id">
      <view class="item-main">
        <view class="amount-info">
          <text class="amount">¥{{item.rechargeAmount}}</text>
          <text class="label">充值金额</text>
        </view>
        <view class="discount-info">
          <text class="discount">{{item.discountPercentage}}%</text>
          <text class="label">折扣</text>
        </view>
        <view class="date-info">
          <text class="date">{{item.effectiveDate}}</text>
          <text class="label">生效日期</text>
        </view>
        <view class="status-info">
          <switch 
            class="status-switch" 
            checked="{{item.isActive}}" 
            bindchange="toggleStatus" 
            data-item="{{item}}"
            color="#667eea"
          />
        </view>
      </view>
      <view class="item-actions">
        <button class="btn-edit" bindtap="editDiscount" data-item="{{item}}">编辑</button>
        <button class="btn-delete" bindtap="deleteDiscount" data-item="{{item}}">删除</button>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{discountList.length === 0 && !loading}}">
    <view class="empty-icon">💰</view>
    <view class="empty-text">暂无折扣规则</view>
    <view class="empty-desc">点击上方按钮添加第一条折扣规则</view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>
</view>

<!-- 添加/编辑折扣弹窗 -->
<view class="modal-overlay" wx:if="{{showModal}}" bindtap="hideModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <view class="modal-title">{{isEdit ? '编辑折扣规则' : '添加折扣规则'}}</view>
      <view class="modal-close" bindtap="hideModal">×</view>
    </view>
    
    <view class="modal-body">
      <view class="form-item">
        <text class="form-label">充值金额 (元) *</text>
        <input class="form-input" type="digit" placeholder="请输入充值金额" 
               value="{{form.rechargeAmount}}" bindinput="onAmountInput" />
      </view>
      
      <view class="form-item">
        <text class="form-label">折扣百分比 (%) *</text>
        <input class="form-input" type="digit" placeholder="请输入折扣百分比，如：95表示9.5折" 
               value="{{form.discountPercentage}}" bindinput="onDiscountInput" />
      </view>
      
      <view class="form-item">
        <text class="form-label">生效日期 *</text>
        <view class="picker-view readonly">
          <text class="picker-text">{{form.effectiveDate}}</text>
        </view>
      </view>
      
      <view class="form-item">
        <text class="form-label">状态</text>
        <switch checked="{{form.isActive}}" bindchange="onStatusChange" />
        <text class="status-text">{{form.isActive ? '启用' : '禁用'}}</text>
      </view>
    </view>
    
    <view class="modal-footer">
      <button class="btn-cancel" bindtap="hideModal">取消</button>
      <button class="btn-confirm" bindtap="submitForm">{{isEdit ? '更新' : '添加'}}</button>
    </view>
  </view>
</view>
